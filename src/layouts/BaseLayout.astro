---
import "../styles/global.css";
import favicon from "../../assets/pngs/lo_fav.png";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "LokalOptimal - Google Business Profil Optimierung",
  description = "LokalOptimal optimiert Google Business Profile für lokale Unternehmen, damit mehr Sichtbarkeit, Vertrauen und Anfragen entstehen.",
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#4965f5" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/png" href={favicon.src} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,400..700,0..1,-50..200&display=swap" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
