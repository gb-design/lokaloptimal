---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout title="Impressum - LokalOptimal">
  <Header />
  <main class="legal-page">
    <article class="container panel-shell">
      <div class="panel-core legal-core">
        <h1 class="h2">Impressum</h1>
        <p>Angaben gemäß § 5 ECG und § 14 UGB.</p>
        <p><strong>LokalOptimal</strong><br />Bitte Unternehmensdaten, Adresse, UID und vertretungsberechtigte Person ergänzen.</p>
        <p><strong>Kontakt</strong><br />E-Mail: bitte-ergaenzen@example.com</p>
        <p><strong>Hinweis</strong><br />Dieser Platzhalter ersetzt keine Rechtsberatung und muss vor Veröffentlichung geprüft werden.</p>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
