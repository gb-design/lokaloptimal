---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import MotionScript from "@/components/MotionScript.astro";
import GBPAuditWidget from "@/components/GBPAuditWidget";
import ContactForm from "@/components/ContactForm";
import addonArticlesImage from "../../assets/avif/addon-articles.avif";
import addonLandingpageImage from "../../assets/avif/addon-landingpage.avif";
import addonQrImage from "../../assets/avif/addon-qr.avif";
import heroBrowserImage from "../../assets/avif/hero-visual/chrome-browser.avif";
import heroPinImage from "../../assets/avif/hero-visual/pin-marker.avif";
import heroProfileCardImage from "../../assets/avif/hero-visual/profile-card.avif";
import heroScoreCardImage from "../../assets/avif/hero-visual/score-card.avif";

const calUrl = import.meta.env.PUBLIC_CAL_URL || "https://cal.com/DEIN-USERNAME/gbp-audit";

const industries = [
  ["Notar", "business_center"],
  ["Hausarzt", "medical_services"],
  ["Internist", "stethoscope"],
  ["Anwalt", "balance"],
  ["Steuerberater", "query_stats"],
  ["Agenturen", "hub"],
  ["Tierarzt", "pets"],
  ["Autohändler", "directions_car"],
  ["Handwerker", "construction"],
  ["Installateur", "shower"],
  ["Wellness", "spa"],
  ["Zahnarzt", "dentistry"],
  ["Restaurants", "restaurant"],
  ["Friseure", "content_cut"],
  ["Frauenarzt", "gynecology"],
  ["Fitness Studio", "fitness_center"],
  ["Cafes", "local_cafe"],
];

const industryColumns = [
  {
    direction: "down",
    items: industries.slice(8),
  },
  {
    direction: "up",
    items: industries.slice(0, 8),
  },
];

const benefits = [
  {
    icon: "search",
    value: 76,
    decimals: 0,
    suffix: "%",
    color: "green",
    layout: "tall",
    text: "Besuchen nach lokaler Suche innerhalb von 24 Stunden ein Unternehmen.",
  },
  {
    icon: "star",
    value: 88,
    decimals: 0,
    suffix: "%",
    color: "amber",
    layout: "wide",
    text: "Vertrauen Online-Bewertungen fast wie persönlichen Empfehlungen.",
  },
  {
    icon: "equalizer",
    value: 50,
    decimals: 0,
    suffix: "%",
    color: "red",
    layout: "compact",
    text: "Mehr Kaufbereitschaft bei einem vollständigen Profil.",
  },
  {
    icon: "verified_user",
    value: 2.7,
    decimals: 1,
    suffix: "x",
    color: "blue",
    layout: "compact",
    text: "Mehr Vertrauen durch klare Infos, Fotos und Bewertungen.",
  },
];

const tabs = [
  {
    name: "QR Review Trigger",
    title: "QR Review Trigger",
    subtitle: "Mehr Bewertungen. Weniger Reibung. Mehr Vertrauen.",
    icon: "qr_code_2",
    image: addonQrImage.src,
    imageAlt: "Vorschau eines QR-Code-Aufstellers, der Kunden direkt zur Google-Bewertung führt.",
    points: ["Kundinnen und Kunden direkt vor Ort zur Bewertung führen.", "Der QR-Code öffnet den Bewertungsprozess ohne Umwege.", "Individuell mit Logo, Text und klarer Handlungsaufforderung gestaltet."],
    closingText: "Optimal für Betriebe, die zufriedene Kunden nicht dem Zufall überlassen möchten.",
  },
  {
    name: "Google Beiträge",
    title: "Google Beiträge",
    subtitle: "Aktuell bleiben. Sichtbar wirken. Vertrauen stärken.",
    icon: "article",
    image: addonArticlesImage.src,
    imageAlt: "Vorschau geplanter Google-Beiträge mit aktuellen Angeboten und Profil-Updates.",
    points: ["Regelmäßige Updates direkt im Google Business Profil veröffentlichen.", "Angebote, News oder saisonale Aktionen sichtbar platzieren.", "Ein aktives Profil wirkt gepflegter und professioneller."],
    closingText: "Ideal für Unternehmen, die regelmäßig sichtbar bleiben möchten.",
  },
  {
    name: "Landingpages",
    title: "Landingpages",
    subtitle: "Wenn der Klick nicht ins Leere laufen soll.",
    icon: "wysiwyg",
    image: addonLandingpageImage.src,
    imageAlt: "Vorschau einer kompakten Landingpage als Anschlussstrecke vom Google-Profil zur Anfrage.",
    points: ["Kompakte Seite für Unternehmen ohne starke Website.", "Klarer Aufbau mit Leistungen, Vertrauen und Kontaktmöglichkeit.", "Optimiert als Anschlussstrecke von Google Profil zur Anfrage."],
    closingText: "Perfekt, wenn das Google Profil mehr leisten soll als nur gefunden werden.",
  },
];

const packages = [
  { name: "Starter", badge: "Einmalig", price: "€287", period: "einmalig", text: "Der perfekte Einstieg für ein professionelles Profil-Setup.", items: ["GBP Audit & Analyse", "Vollständiges Profil-Setup", "Kategorien, Texte, Öffnungszeiten"] },
  { name: "Essential", badge: "Einmalig", price: "€497", period: "einmalig", text: "Für einen starken ersten Eindruck mit den wichtigsten Extras.", items: ["Alles aus Starter", "Foto-Briefing Dokument", "1x Google Post"] },
  { name: "Growth", badge: "3 Monate", price: "€1.397", period: "3 Monate Laufzeit", text: "Aktives Management für mehr Sichtbarkeit und Interaktionen.", items: ["Alles aus Essential", "3 Monate aktives Management", "4x Google Posts / Monat", "Review-Monitoring & Antworten", "Monatliches PDF-Reporting"], featured: true },
  { name: "Local Pro", badge: "6 Monate", price: "€2.697", period: "6 Monate Laufzeit", text: "Die Komplettlösung für nachhaltiges Wachstum & maximale Präsenz.", items: ["Alles aus Growth", "6 Monate aktives Management", "8x Google Posts / Monat", "Review- & Q&A Management", "Strategie-Call pro Monat"] },
];

const addons = [
  {
    name: "Extra Google Posts",
    sub: "+4 / Monat",
    price: "€97",
    period: "/ Monat",
    tooltip: "Hält Ihr Profil sichtbar aktiv und bringt aktuelle Angebote, News oder Aktionen direkt in die Google-Suche.",
  },
  {
    name: "Review-Response Service",
    sub: "",
    price: "€127",
    period: "/ Monat",
    tooltip: "Zeigt Interessenten, dass Ihr Unternehmen auf Feedback reagiert und Kunden ernst nimmt.",
  },
  {
    name: "Landingpage",
    sub: "1-Pager",
    price: "€797",
    period: "einmalig",
    tooltip: "Führt Besucher nach dem Google-Klick gezielt zur Anfrage statt sie auf einer unklaren Website zu verlieren.",
  },
  {
    name: "Konkurrenzanalyse",
    sub: "3 Mitbewerber",
    price: "€197",
    period: "einmalig",
    tooltip: "Macht sichtbar, wo Mitbewerber stärker auftreten und welche Chancen Ihr Profil noch nutzen kann.",
  },
  {
    name: "Foto-Briefing Dokument",
    sub: "",
    price: "€97",
    period: "einmalig",
    tooltip: "Hilft Ihnen, genau die Bilder zu erstellen, die Vertrauen aufbauen und Ihr Profil professioneller wirken lassen.",
  },
  {
    name: "Q&A Management",
    sub: "monatlich",
    price: "€79",
    period: "/ Monat",
    tooltip: "Beantwortet typische Fragen direkt im Profil und reduziert Unsicherheit vor der Kontaktaufnahme.",
  },
];

const testimonials = [
  {
    quote: "Das Profil wirkt endlich aufgeräumt und professionell. Besonders hilfreich war, dass wir jetzt klar sehen, welche Inhalte im Google-Profil wirklich zählen.",
    name: "Martin H.",
    company: "Steuerkanzlei Huber",
    location: "Wien",
    rating: 5,
  },
  {
    quote: "Die Optimierung hat uns geholfen, bei lokalen Suchanfragen seriöser aufzutreten. Der Ablauf war verständlich und ohne unnötigen Fachjargon.",
    name: "Sabine K.",
    company: "Praxis am Stadtpark",
    location: "Klosterneuburg",
    rating: 4,
  },
  {
    quote: "Unsere Öffnungszeiten, Leistungen und Fotos sind jetzt konsistent. Genau diese saubere Basis hat uns vorher gefehlt.",
    name: "Daniel R.",
    company: "R&R Installationen",
    location: "Wien-Umgebung",
    rating: 4,
  },
  {
    quote: "Gute Struktur und schnelle Umsetzung. Bei den laufenden Beiträgen hätten wir uns anfangs noch mehr Beispiele gewünscht, inzwischen passt es sehr gut.",
    name: "Nina F.",
    company: "Salon Frey",
    location: "Wien",
    rating: 3,
  },
  {
    quote: "Die Pflege der Bewertungen und die klareren Profilinfos machen einen spürbar besseren ersten Eindruck bei neuen Kundinnen und Kunden.",
    name: "Thomas M.",
    company: "Autohaus Mayer",
    location: "Wien-Umgebung",
    rating: 5,
  },
];
---

<BaseLayout>
  <Header />

  <main>
    <section class="hero">
      <div class="container-wide hero-grid">
        <div class="hero-copy reveal is-visible">
          <p class="hero-kicker"><span aria-hidden="true">🚀</span> Boosten Sie Ihr Google Business Profil - <strong>noch heute!</strong></p>
          <h1 class="h1">
            <span>Weil der erste</span>
            <span>Eindruck zählt.</span>
            <span class="text-blue">Auf Google.</span>
          </h1>
          <div class="hero-actions">
            <a class="btn btn-primary" href={import.meta.env.PUBLIC_CAL_URL || "https://cal.com/DEIN-USERNAME/gbp-audit"} target="_blank" rel="noreferrer">
              Kostenloses Erstgespräch
              <span class="btn-icon"><span class="material-symbols-rounded" aria-hidden="true">arrow_forward</span></span>
            </a>
            <a class="learn-link" href="#quick-check">Mehr erfahren</a>
          </div>
        </div>

        <div class="hero-visual" data-gsap="parallax">
          <div class="hero-visual-stack">
            <img
              class="hero-browser-image"
              src={heroBrowserImage.src}
              width={heroBrowserImage.width}
              height={heroBrowserImage.height}
              alt="Google-Business-Profil in einer Kartenansicht mit Profilstärke und Standortmarker."
              loading="eager"
              decoding="async"
            />
            <img
              class="hero-profile-card-image"
              src={heroProfileCardImage.src}
              width={heroProfileCardImage.width}
              height={heroProfileCardImage.height}
              alt=""
              loading="eager"
              decoding="async"
            />
            <img
              class="hero-score-card-image"
              src={heroScoreCardImage.src}
              width={heroScoreCardImage.width}
              height={heroScoreCardImage.height}
              alt=""
              loading="eager"
              decoding="async"
            />
            <img
              class="hero-pin-image"
              src={heroPinImage.src}
              width={heroPinImage.width}
              height={heroPinImage.height}
              alt=""
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>

      <div class="container trust-cluster reveal is-visible">
        <div class="trust-row">
          <span><i class="material-symbols-rounded" aria-hidden="true">check_circle</i>Mehr Sichtbarkeit</span>
          <span><i class="material-symbols-rounded" aria-hidden="true">check_circle</i>Mehr Vertrauen</span>
          <span><i class="material-symbols-rounded" aria-hidden="true">check_circle</i>Mehr Anfragen</span>
        </div>
        <span class="expert-badge"><span class="material-symbols-rounded" aria-hidden="true">hotel_class</span>Google Business Profil Experte</span>
      </div>
    </section>

    <section class="section check-section" id="quick-check">
      <div class="container section-heading" data-gsap="reveal">
        <span class="map-icon" aria-hidden="true"><span>G</span></span>
        <h2 class="h2">Machen Sie einen <span class="text-blue">kostenlosen</span> GBP-Check</h2>
        <p class="lead">Einfach bestehende Google Business Profil-URL eingeben und prüfen lassen.</p>
      </div>
      <div class="panel-shell widget-shell" data-gsap="reveal">
        <div class="panel-core widget-core">
          <GBPAuditWidget client:load />
        </div>
      </div>
    </section>

    <section class="section industries-section">
      <div class="container industries-grid">
        <div data-gsap="reveal">
          <span class="eyebrow"><span class="material-symbols-rounded" aria-hidden="true">storefront</span>Für lokale Unternehmen</span>
          <h2 class="h2">Mehr Sichtbarkeit für jede Branche</h2>
          <p class="lead"><strong>LokalOptimal</strong> hilft Unternehmen, dort besser sichtbar zu werden, wo Kund:innen aktiv suchen - auf Google.</p>
        </div>
        <div class="industry-marquee" data-gsap="reveal" aria-label="Branchen">
          {industryColumns.map((column) => (
            <div class={`industry-column ${column.direction}`}>
              <div class="industry-track">
                {Array.from({ length: 2 }).map((_, groupIndex) => (
                  <div class="industry-group" aria-hidden={groupIndex === 1 ? "true" : undefined}>
                    {column.items.map(([industry, icon]) => (
                      <span class="industry-pill">
                        <i class="material-symbols-rounded" aria-hidden="true">{icon}</i>{industry}
                      </span>
                    ))}
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section benefits-section" id="vorteile">
      <div class="container section-heading" data-gsap="reveal">
        <span class="stars" aria-label="Fünf Sterne">
          {Array.from({ length: 5 }).map(() => <span class="material-symbols-rounded" aria-hidden="true">star</span>)}
        </span>
        <h2 class="h2">Warum ein gepflegtes Google-Profil mehr ist, als ein Brancheneintrag</h2>
      </div>
      <div class="container benefit-bento" aria-label="Vorteile in Zahlen">
        {benefits.map((benefit) => (
          <article class={`benefit-stat-card is-${benefit.layout} tone-${benefit.color}`} data-gsap="reveal">
            <div class="benefit-shape" aria-hidden="true"></div>
            <div class="benefit-stat-head">
              <span class="benefit-stat-icon material-symbols-rounded" aria-hidden="true">{benefit.icon}</span>
              <strong class="benefit-stat-value">
                <span
                  data-count-up
                  data-count-target={benefit.value}
                  data-count-decimals={benefit.decimals}
                >0</span>
                <small>{benefit.suffix}</small>
              </strong>
            </div>
            <p>{benefit.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section addon-showcase" id="wirkung">
      <div class="container section-heading" data-gsap="reveal">
        <span class="eyebrow"><span class="material-symbols-rounded" aria-hidden="true">extension</span>Add-ons für mehr Wirkung</span>
        <h2 class="h2">Ergänzen Sie Ihr Profil mit <span class="text-blue">starken Add-ons</span></h2>
        <p class="lead">Maximieren Sie Vertrauen, Interaktionen und Anfragen - mit den richtigen Bausteinen für Ihren Google-Auftritt.</p>
      </div>
      <div class="container addon-grid">
        <div class="panel-shell addon-tabs" data-gsap="reveal">
          <div class="panel-core">
            <div class="tab-nav" role="tablist" aria-label="Add-ons">
              {tabs.map((tab, index) => (
                <button
                  id={`addon-tab-${index}`}
                  class={index === 0 ? "active" : ""}
                  type="button"
                  role="tab"
                  aria-selected={index === 0 ? "true" : "false"}
                  aria-controls={`addon-panel-${index}`}
                  tabindex={index === 0 ? "0" : "-1"}
                  data-tab-index={index}
                >
                  {tab.name}
                </button>
              ))}
            </div>
            {tabs.map((tab, index) => (
              <div
                id={`addon-panel-${index}`}
                class="tab-content"
                role="tabpanel"
                aria-labelledby={`addon-tab-${index}`}
                data-tab-index={index}
                hidden={index !== 0}
              >
                <span class="tab-icon material-symbols-rounded" aria-hidden="true">{tab.icon}</span>
                <h3>{tab.title}</h3>
                <strong>{tab.subtitle}</strong>
                <ul>
                  {tab.points.map((point) => <li>{point}</li>)}
                </ul>
                <p class="tab-closing">{tab.closingText}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="review-visual panel-shell addon-visual" data-gsap="reveal">
          <div class="panel-core addon-visual-core">
            {tabs.map((tab, index) => (
              <img
                src={tab.image}
                alt={tab.imageAlt}
                loading={index === 0 ? "eager" : "lazy"}
                decoding="async"
                data-tab-index={index}
                hidden={index !== 0}
              />
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section pricing-section" id="preise">
      <div class="container section-heading" data-gsap="reveal">
        <span class="eyebrow"><span class="material-symbols-rounded" aria-hidden="true">inventory_2</span>Unsere Pakete</span>
        <h2 class="h2">Das passende Paket für <span class="text-blue">Ihren Google-Auftritt</span></h2>
      </div>
      <div class="container-wide pricing-grid">
        {packages.map((pkg) => (
          <article class={`price-card panel-shell ${pkg.featured ? "featured" : ""}`} data-gsap="reveal">
            <div class="panel-core price-core">
              <div class="price-meta">
                <span class="package-badge">{pkg.badge}</span>
                {pkg.featured && (
                  <span class="recommended">
                    <span class="material-symbols-rounded" aria-hidden="true">verified</span>
                    Empfohlen
                  </span>
                )}
              </div>
              <div class="price-head">
                <h3>{pkg.name}</h3>
              </div>
              <p>{pkg.text}</p>
              <strong class="price">{pkg.price}</strong>
              <small>{pkg.period}</small>
              <ul>
                {pkg.items.map((item) => <li>{item}</li>)}
              </ul>
              <a
                class={`btn ${pkg.featured ? "btn-primary" : "btn-secondary"}`}
                href="#kontakt"
                aria-label={`${pkg.name} Paket anfragen`}
              >
                Anfragen <span class="btn-icon"><span class="material-symbols-rounded" aria-hidden="true">arrow_forward</span></span>
              </a>
            </div>
          </article>
        ))}
      </div>

      <p class="price-note container">Alle Preise verstehen sich zzgl. MwSt. Zahlung: 50 % Anzahlung bei Auftragserteilung, 50 % nach Abschluss.</p>

      <div class="container section-heading compact" data-gsap="reveal">
        <span class="eyebrow"><span class="material-symbols-rounded" aria-hidden="true">add_circle</span>Zusätzliche Add-ons</span>
        <h2 class="h3">Erweitern Sie Ihr Paket <span class="text-blue">nach Bedarf</span></h2>
      </div>
      <div class="container addon-price-grid">
        {addons.map(({ name, sub, price, period, tooltip }) => (
          <details class="addon-price panel-shell" data-gsap="reveal">
            <summary class="panel-core">
              <span class="material-symbols-rounded addon-icon" aria-hidden="true">auto_awesome</span>
              <div><strong>{name}</strong>{sub && <small>{sub}</small>}</div>
              <b>{price}<small>{period}</small></b>
              <span class="material-symbols-rounded addon-toggle" aria-hidden="true">expand_more</span>
              <span class="addon-tooltip">{tooltip}</span>
            </summary>
          </details>
        ))}
      </div>
      <div class="container important-note" data-gsap="reveal">
        <strong>Wichtiger Hinweis:</strong> LokalOptimal optimiert und pflegt Ihr Google Business Profil nach aktuellen Best Practices. Konkrete Rankingversprechen werden bewusst nicht gegeben.
      </div>
    </section>

    <section class="section testimonials-section" id="kundenstimmen">
      <div class="container section-heading" data-gsap="reveal">
        <span class="eyebrow"><span class="material-symbols-rounded" aria-hidden="true">reviews</span>Kundenstimmen</span>
        <h2 class="h2">Was lokale Unternehmen über <span class="text-blue">LokalOptimal</span> sagen</h2>
        <p class="lead">Platzhalterstimmen aus typischen lokalen Betrieben - als Vorschau für echte Referenzen.</p>
      </div>

      <div
        class="container-wide testimonial-slider"
        data-gsap="reveal"
        tabindex="0"
        role="region"
        aria-roledescription="Karussell"
        aria-label="Testimonials Slider. Mit Pfeiltasten links und rechts navigieren."
      >
        <div class="testimonial-viewport">
          <div class="testimonial-track">
            {testimonials.map((testimonial) => (
              <article class="testimonial-card" aria-label={`${testimonial.rating} von 5 Sternen`}>
                <div class="testimonial-stars" aria-hidden="true">
                  {Array.from({ length: 5 }).map((_, index) => (
                    <span class={`material-symbols-rounded ${index >= testimonial.rating ? "inactive" : ""}`}>star</span>
                  ))}
                </div>
                <blockquote>{testimonial.quote}</blockquote>
                <div class="testimonial-author">
                  <strong>{testimonial.name}</strong>
                  <span>{testimonial.company}</span>
                  <small><span class="material-symbols-rounded" aria-hidden="true">location_on</span>{testimonial.location}</small>
                </div>
              </article>
            ))}
          </div>
        </div>

        <div class="testimonial-controls" aria-label="Testimonials Navigation">
          <button class="testimonial-arrow" type="button" data-testimonial-prev aria-label="Vorheriges Testimonial">
            <span class="material-symbols-rounded" aria-hidden="true">chevron_left</span>
          </button>
          <div class="testimonial-dots" aria-label="Testimonial Position"></div>
          <button class="testimonial-arrow" type="button" data-testimonial-next aria-label="Nächstes Testimonial">
            <span class="material-symbols-rounded" aria-hidden="true">chevron_right</span>
          </button>
        </div>
      </div>
    </section>

    <section class="section contact-section" id="kontakt">
      <div class="container contact-grid">
        <div data-gsap="reveal">
          <span class="eyebrow"><span class="material-symbols-rounded" aria-hidden="true">forum</span>Kontakt</span>
          <h2 class="h2">Lassen Sie uns Ihren lokalen Auftritt sauber einordnen.</h2>
          <p class="lead">Schicken Sie eine kurze Anfrage oder buchen Sie direkt einen Termin. Der erste Check ist kostenlos und unverbindlich.</p>
          <a class="btn btn-secondary contact-cal" href={calUrl} target="_blank" rel="noreferrer" data-cal-open>Kostenloses Erstgespräch buchen</a>
        </div>
        <div class="panel-shell" data-gsap="reveal">
          <div class="panel-core contact-core">
            <ContactForm client:visible />
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <MotionScript />
  <script>
    document.querySelectorAll<HTMLElement>(".addon-tabs").forEach((tabsRoot) => {
      const addonGrid = tabsRoot.closest<HTMLElement>(".addon-grid");
      const tabs = Array.from(tabsRoot.querySelectorAll<HTMLButtonElement>("[role='tab']"));
      const panels = Array.from(tabsRoot.querySelectorAll<HTMLElement>("[role='tabpanel']"));
      const images = Array.from(addonGrid?.querySelectorAll<HTMLImageElement>(".addon-visual img") ?? []);

      const activateTab = (nextIndex: number, shouldFocus = false) => {
        tabs.forEach((tab, index) => {
          const isActive = index === nextIndex;
          tab.classList.toggle("active", isActive);
          tab.setAttribute("aria-selected", String(isActive));
          tab.tabIndex = isActive ? 0 : -1;
          if (isActive && shouldFocus) tab.focus();
        });

        panels.forEach((panel, index) => {
          panel.hidden = index !== nextIndex;
        });

        images.forEach((image, index) => {
          image.hidden = index !== nextIndex;
        });
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => activateTab(index));
        tab.addEventListener("keydown", (event) => {
          const lastIndex = tabs.length - 1;
          let nextIndex = index;

          if (event.key === "ArrowRight") nextIndex = index === lastIndex ? 0 : index + 1;
          else if (event.key === "ArrowLeft") nextIndex = index === 0 ? lastIndex : index - 1;
          else if (event.key === "Home") nextIndex = 0;
          else if (event.key === "End") nextIndex = lastIndex;
          else return;

          event.preventDefault();
          activateTab(nextIndex, true);
        });
      });
    });

    document.querySelectorAll<HTMLElement>(".testimonial-slider").forEach((slider) => {
      const track = slider.querySelector<HTMLElement>(".testimonial-track");
      const viewport = slider.querySelector<HTMLElement>(".testimonial-viewport");
      const cards = Array.from(slider.querySelectorAll<HTMLElement>(".testimonial-card"));
      const previousButton = slider.querySelector<HTMLButtonElement>("[data-testimonial-prev]");
      const nextButton = slider.querySelector<HTMLButtonElement>("[data-testimonial-next]");
      const dotsRoot = slider.querySelector<HTMLElement>(".testimonial-dots");
      let activeIndex = 0;
      let maxIndex = 0;
      let dragStartX = 0;
      let dragDeltaX = 0;
      let isDragging = false;

      if (!track || !viewport || cards.length === 0 || !previousButton || !nextButton || !dotsRoot) return;

      const getVisibleCount = () => {
        if (window.matchMedia("(max-width: 700px)").matches) return 1;
        if (window.matchMedia("(max-width: 1080px)").matches) return 2;
        return 3;
      };

      const getStep = () => {
        if (cards.length < 2) return cards[0]?.offsetWidth ?? 0;
        return cards[1].offsetLeft - cards[0].offsetLeft;
      };

      const renderDots = () => {
        dotsRoot.replaceChildren();
        Array.from({ length: maxIndex + 1 }).forEach((_, index) => {
          const dot = document.createElement("button");
          dot.className = "testimonial-dot";
          dot.type = "button";
          dot.setAttribute("aria-label", `Testimonial Gruppe ${index + 1} anzeigen`);
          dot.addEventListener("click", () => setIndex(index));
          dotsRoot.append(dot);
        });
      };

      const update = () => {
        const step = getStep();
        track.style.transform = `translate3d(${-activeIndex * step}px, 0, 0)`;
        previousButton.disabled = activeIndex === 0;
        nextButton.disabled = activeIndex === maxIndex;

        Array.from(dotsRoot.querySelectorAll<HTMLButtonElement>(".testimonial-dot")).forEach((dot, index) => {
          const isActive = index === activeIndex;
          dot.classList.toggle("active", isActive);
          dot.toggleAttribute("aria-current", isActive);
        });
      };

      const updateDrag = () => {
        const step = getStep();
        const baseX = -activeIndex * step;
        const isAtStart = activeIndex === 0 && dragDeltaX > 0;
        const isAtEnd = activeIndex === maxIndex && dragDeltaX < 0;
        const resistance = isAtStart || isAtEnd ? 0.28 : 1;
        track.style.transform = `translate3d(${baseX + dragDeltaX * resistance}px, 0, 0)`;
      };

      function setIndex(nextIndex: number) {
        activeIndex = Math.max(0, Math.min(nextIndex, maxIndex));
        update();
      }

      const endDrag = () => {
        if (!isDragging) return;

        const step = getStep();
        const threshold = Math.min(step * 0.2, 90);
        const nextIndex = Math.abs(dragDeltaX) > threshold
          ? activeIndex + (dragDeltaX < 0 ? 1 : -1)
          : activeIndex;

        isDragging = false;
        slider.classList.remove("is-dragging");
        dragDeltaX = 0;
        setIndex(nextIndex);
      };

      const refresh = () => {
        maxIndex = Math.max(cards.length - getVisibleCount(), 0);
        activeIndex = Math.min(activeIndex, maxIndex);
        renderDots();
        update();
      };

      previousButton.addEventListener("click", () => setIndex(activeIndex - 1));
      nextButton.addEventListener("click", () => setIndex(activeIndex + 1));
      viewport.addEventListener("pointerdown", (event) => {
        if (event.button !== 0 && event.pointerType === "mouse") return;

        isDragging = true;
        dragStartX = event.clientX;
        dragDeltaX = 0;
        slider.classList.add("is-dragging");
        viewport.setPointerCapture(event.pointerId);
      });
      viewport.addEventListener("pointermove", (event) => {
        if (!isDragging) return;

        dragDeltaX = event.clientX - dragStartX;
        updateDrag();
      });
      viewport.addEventListener("pointerup", endDrag);
      viewport.addEventListener("pointercancel", endDrag);
      viewport.addEventListener("lostpointercapture", endDrag);
      slider.addEventListener("keydown", (event) => {
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          setIndex(activeIndex - 1);
        } else if (event.key === "ArrowRight") {
          event.preventDefault();
          setIndex(activeIndex + 1);
        }
      });

      refresh();
      window.addEventListener("resize", refresh);
    });
  </script>
</BaseLayout>
