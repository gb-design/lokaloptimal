<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const isDesktop = window.matchMedia("(min-width: 768px)").matches;
  const header = document.querySelector<HTMLElement>(".site-header");

  if (header) {
    let lastScrollY = window.scrollY;
    let ticking = false;

    const updateHeader = () => {
      const currentScrollY = window.scrollY;
      const isMenuOpen = document.body.hasAttribute("data-menu-open");
      const isScrollingDown = currentScrollY > lastScrollY;

      if (currentScrollY <= 8 || isMenuOpen || !isScrollingDown) {
        header.classList.remove("is-hidden");
      } else if (currentScrollY > 80) {
        header.classList.add("is-hidden");
      }

      lastScrollY = Math.max(currentScrollY, 0);
      ticking = false;
    };

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          window.requestAnimationFrame(updateHeader);
          ticking = true;
        }
      },
      { passive: true },
    );
  }

  const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>(".nav-links a[href^='#']"));
  const navSections = navLinks
    .map((link) => {
      const target = document.querySelector<HTMLElement>(link.hash);
      return target ? { link, target } : null;
    })
    .filter((item): item is { link: HTMLAnchorElement; target: HTMLElement } => Boolean(item));

  if (navSections.length > 0) {
    const setActiveLink = () => {
      const headerOffset = header?.offsetHeight ?? 0;
      const activePoint = window.scrollY + headerOffset + 120;
      const activeSection =
        [...navSections]
          .reverse()
          .find(({ target }) => target.offsetTop <= activePoint) ?? null;

      navLinks.forEach((link) => {
        const isActive = activeSection ? link === activeSection.link : false;
        link.classList.toggle("active", isActive);
        link.toggleAttribute("aria-current", isActive);
      });
    };

    setActiveLink();
    window.addEventListener("scroll", setActiveLink, { passive: true });
    window.addEventListener("resize", setActiveLink);
  }

  const countUpElements = Array.from(document.querySelectorAll<HTMLElement>("[data-count-up]"));
  const numberFormatter = (decimals: number) =>
    new Intl.NumberFormat("de-DE", {
      minimumFractionDigits: decimals,
      maximumFractionDigits: decimals,
    });

  const setCountValue = (element: HTMLElement, value: number, decimals: number) => {
    element.textContent = numberFormatter(decimals).format(value);
  };

  const animateCount = (element: HTMLElement) => {
    if (element.dataset.countStarted === "true") return;

    const target = Number(element.dataset.countTarget ?? "0");
    const decimals = Number(element.dataset.countDecimals ?? "0");
    const duration = target < 10 ? 1200 : 1450;
    const start = performance.now();

    element.dataset.countStarted = "true";

    const tick = (now: number) => {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      setCountValue(element, target * eased, decimals);

      if (progress < 1) {
        window.requestAnimationFrame(tick);
      } else {
        setCountValue(element, target, decimals);
      }
    };

    window.requestAnimationFrame(tick);
  };

  if (countUpElements.length > 0) {
    if (reduceMotion) {
      countUpElements.forEach((element) => {
        setCountValue(element, Number(element.dataset.countTarget ?? "0"), Number(element.dataset.countDecimals ?? "0"));
      });
    } else {
      const shouldCountPerCard = window.matchMedia("(max-width: 860px)").matches;
      const countAll = () => countUpElements.forEach((element) => animateCount(element));
      const countObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            if (shouldCountPerCard) {
              entry.target.querySelectorAll<HTMLElement>("[data-count-up]").forEach((element) => animateCount(element));
            } else {
              countAll();
            }
            observer.unobserve(entry.target);
          });
        },
        { rootMargin: "0px 0px -18% 0px", threshold: 0.18 },
      );

      if (shouldCountPerCard) {
        document.querySelectorAll<HTMLElement>("#vorteile .benefit-stat-card").forEach((card) => countObserver.observe(card));
      } else {
        countObserver.observe(document.querySelector("#vorteile .benefit-bento") ?? countUpElements[0]);
      }
    }
  }

  if (!reduceMotion) {
    gsap.registerPlugin(ScrollTrigger);

    gsap.utils.toArray<HTMLElement>("[data-gsap='reveal']").forEach((element, index) => {
      const revealOffset = element.closest(".check-section") ? 16 : 42;

      gsap.fromTo(
        element,
        { autoAlpha: 0, y: revealOffset },
        {
          autoAlpha: 1,
          y: 0,
          duration: 0.9,
          delay: Math.min(index * 0.04, 0.18),
          ease: "power3.out",
          scrollTrigger: {
            trigger: element,
            start: "top 86%",
            once: true,
            toggleActions: "play none none none",
          },
        },
      );
    });

    if (isDesktop) {
      gsap.utils.toArray<HTMLElement>("[data-gsap='parallax']").forEach((element) => {
        gsap.to(element, {
          yPercent: -7,
          ease: "none",
          scrollTrigger: {
            trigger: element,
            start: "top bottom",
            end: "bottom top",
            scrub: 0.65,
          },
        });
      });
    }

  } else {
    document.querySelectorAll(".reveal, [data-gsap='reveal']").forEach((element) => element.classList.add("is-visible"));
  }
</script>
