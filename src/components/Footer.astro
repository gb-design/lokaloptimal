---
import logoRaw from "../../assets/lo_logo.svg?raw";

const year = new Date().getFullYear();
const footerLogo = logoRaw
  .replace("<svg ", '<svg class="brand-logo footer-logo" aria-hidden="true" focusable="false" ')
  .replace('<path d="M147.9', '<path class="footer-logo-local" d="M147.9');
---

<footer class="footer">
  <div class="container-wide footer-grid">
    <div>
      <a class="brand footer-brand" href="/" aria-label="LokalOptimal Startseite">
        <span class="footer-logo-inline" set:html={footerLogo} />
      </a>
      <p>Google Business Profil Optimierung für lokale Unternehmen, die genau dort sichtbar werden wollen, wo Kund:innen suchen.</p>
    </div>

    <div>
      <h2>Leistungen</h2>
      <a href="/#quick-check">GBP Quick Check</a>
      <a href="/#preise">Pakete</a>
      <a href="/#kontakt">Kontakt</a>
    </div>

    <div>
      <h2>Rechtliches</h2>
      <a href="/impressum">Impressum</a>
      <a href="/datenschutz">Datenschutz</a>
      <a href="/agb">AGB</a>
    </div>
  </div>

  <div class="container-wide footer-bottom">
    <span>© {year} LokalOptimal</span>
    <span>Keine Ranking-Garantien. Saubere Optimierung nach aktuellen Best Practices.</span>
  </div>
</footer>
